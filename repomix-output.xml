/* Chat Components Module
 * Chat modal, messages, input, and related components
 */

/* Chat FAB Button */
.chat-fab {
  position: fixed;
  bottom: 1.5rem;
  right: 1.5rem;
  z-index: 50;
  height: 3.5rem;
  width: 3.5rem;
  border-radius: 9999px;
  box-shadow: var(--shadow-lg);
}

/* Chat Modal Overlay */
.chat-modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  backdrop-filter: blur(4px);
  display: flex;
  align-items: flex-end;
  justify-content: flex-end;
  z-index: 200;
  animation: fadeIn var(--transition-base);
}

.chat-modal-overlay.hidden {
  display: none;
}

/* Chat Modal */
.chat-modal {
  background-color: var(--color-background-secondary);
  border: none;
  border-radius: 12px;
  width: 100%;
  max-width: 400px;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  box-shadow: var(--shadow-xl);
  margin: var(--spacing-lg);
  animation: slideUp var(--transition-base);
  position: fixed !important;
  left: auto !important;
  right: var(--spacing-lg) !important;
  top: auto !important;
  bottom: var(--spacing-lg) !important;
  transform: none !important;
}

/* Chat Modal Header */
.chat-modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--spacing-lg);
  border-bottom: none;
}

.chat-modal-header h3 {
  color: var(--color-primary);
  font-weight: var(--font-weight-semibold);
  font-size: var(--text-lg);
  margin: 0;
}

/* Chat Modal Header Actions */
.chat-modal-header-actions {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
}

/* Chat Modal Close Button */
.chat-modal-close {
  background: none;
  border: none;
  color: var(--color-text-secondary);
  font-size: 1.5rem;
  cursor: pointer;
  padding: 0;
  width: 2rem;
  height: 2rem;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: var(--transition-base);
}

.chat-modal-close:hover {
  color: var(--color-error);
  transform: rotate(90deg);
}

.chat-modal-close:focus {
  box-shadow: var(--focus-ring);
  outline: none;
}

/* Chat Modal Delete Button */
.chat-modal-delete {
  background: none;
  border: none;
  color: var(--color-text-secondary);
  cursor: pointer;
  padding: 0;
  width: 2rem;
  height: 2rem;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: var(--transition-base);
}

.chat-modal-delete svg {
  width: 1.25rem;
  height: 1.25rem;
}

.chat-modal-delete:hover {
  color: var(--color-error);
  transform: scale(1.1);
}

.chat-modal-delete:focus {
  box-shadow: var(--focus-ring);
  outline: none;
}

/* Chat Responsive Container */
.chat-responsive-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  min-height: 0;
}

/* Chat Message List Container */
.chat-message-list-container {
  flex: 1;
  overflow-y: auto;
  padding: var(--spacing-md);
  min-height: 0;
}

/* Chat Input Container */
.chat-input-container {
  border-top: none;
  padding: var(--spacing-md);
  background-color: var(--color-background);
}

/* Chat Message */
.chat-message {
  margin-bottom: var(--spacing-md);
  padding: var(--spacing-md);
  border-radius: 8px;
  animation: fadeIn var(--transition-base);
}

/* Chat Message User */
.chat-message-user {
  background-color: var(--color-primary);
  color: var(--color-background);
  margin-left: auto;
  max-width: 80%;
}

/* Chat Message Assistant */
.chat-message-assistant {
  background-color: var(--color-background-tertiary);
  color: var(--color-text);
  margin-right: auto;
  max-width: 80%;
}

/* Chat Message Content */
.chat-message-content {
  margin-bottom: var(--spacing-sm);
  word-wrap: break-word;
  line-height: var(--line-height-body);
}

.chat-message-assistant .chat-message-content code {
  background-color: var(--color-background-secondary);
  padding: 2px 6px;
  border-radius: 4px;
  font-family: monospace;
  font-size: 0.9em;
}

.chat-message-assistant .chat-message-content strong {
  font-weight: var(--font-weight-bold);
}

.chat-message-assistant .chat-message-content em {
  font-style: italic;
}

/* Chat Message Meta */
.chat-message-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: var(--text-xs);
  opacity: 0.8;
}

/* Chat Message Role */
.chat-message-role {
  display: none;
  font-weight: var(--font-weight-medium);
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

/* Chat Message Timestamp */
.chat-message-timestamp {
  color: var(--color-text-muted);
}

/* User message timestamp - lighter color for visibility on primary background */
.chat-message-user .chat-message-timestamp {
  color: var(--color-background);
  opacity: 0.9;
}

/* Chat Message List */
.chat-message-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
  min-height: 100%;
}

/* Chat Message Empty */
.chat-message-empty {
  text-align: center;
  padding: var(--spacing-xl);
  color: var(--color-text-muted);
  font-style: italic;
}

/* Chat Message Loading */
.chat-message-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-md);
}

/* Loading Dots */
.loading-dots {
  display: flex;
  gap: 4px;
}

.loading-dots span {
  width: 8px;
  height: 8px;
  background-color: var(--color-primary);
  border-radius: 50%;
  animation: bounce 1.4s infinite ease-in-out both;
}

.loading-dots span:nth-child(1) {
  animation-delay: -0.32s;
}

.loading-dots span:nth-child(2) {
  animation-delay: -0.16s;
}

/* Chat Input Wrapper */
.chat-input-wrapper {
  display: flex;
  gap: var(--spacing-sm);
  align-items: flex-end;
}

/* Chat Input Textarea */
.chat-input-textarea {
  flex: 1;
  padding: var(--spacing-md);
  border: 1px solid var(--color-border);
  border-radius: 8px;
  background-color: var(--color-background);
  color: var(--color-text);
  font-family: var(--font-family);
  font-size: var(--text-base);
  resize: none;
  min-height: 44px;
  max-height: 120px;
  transition: var(--transition-base);
}

.chat-input-textarea:focus {
  outline: none;
  border-color: var(--color-primary);
  box-shadow: var(--focus-ring);
}

.chat-input-textarea::placeholder {
  color: var(--color-text-muted);
}

/* Chat Input Send Button */
.chat-input-send {
  padding: var(--spacing-md) var(--spacing-lg);
  background-color: var(--color-primary);
  color: var(--color-background);
  border: none;
  border-radius: 8px;
  font-family: var(--font-family);
  font-size: var(--text-base);
  font-weight: var(--font-weight-semibold);
  cursor: pointer;
  transition: var(--transition-base);
  white-space: nowrap;
  min-height: 44px;
}

.chat-input-send:hover:not(:disabled) {
  opacity: 0.9;
  box-shadow: var(--shadow-md);
}

.chat-input-send:focus {
  outline: none;
  box-shadow: var(--focus-ring);
}

.chat-input-send:active:not(:disabled) {
  transform: scale(0.98);
}

.chat-input-send:disabled {
  opacity: 0.6;
  cursor: not-allowed;
}

/* Text utility classes for chat components */
.chat-modal .font-semibold {
  font-weight: var(--font-weight-semibold);
}

.chat-modal .text-small {
  font-size: var(--text-sm);
}

.chat-modal .mb-1 {
  margin-bottom: var(--spacing-sm);
}

/* Mobile Responsiveness for Chat Components */
@media (max-width: 480px) {
  /* Chat FAB Button - smaller on mobile */
  .chat-fab {
    width: 3rem;
    height: 3rem;
    bottom: 1rem;
    right: 1rem;
  }

  /* Chat Modal - full width on mobile with small margins */
  .chat-modal {
    width: calc(100% - var(--spacing-md));
    max-width: none;
    margin: var(--spacing-sm);
    left: var(--spacing-sm) !important;
    right: var(--spacing-sm) !important;
    bottom: var(--spacing-sm) !important;
    max-height: 90vh;
    border-radius: 8px;
  }

  /* Chat Modal Header - smaller padding */
  .chat-modal-header {
    padding: var(--spacing-md);
  }

  .chat-modal-header h3 {
    font-size: var(--text-base);
  }

  /* Chat Message - reduced padding on mobile */
  .chat-message {
    padding: var(--spacing-sm);
    margin-bottom: var(--spacing-sm);
  }

  /* Chat Message List Container - reduced padding */
  .chat-message-list-container {
    padding: var(--spacing-sm);
  }

  /* Chat Input Container - reduced padding */
  .chat-input-container {
    padding: var(--spacing-sm);
  }

  /* Chat Input Textarea - smaller font on mobile */
  .chat-input-textarea {
    font-size: var(--text-sm);
    min-height: 40px;
    padding: var(--spacing-sm);
  }

  /* Chat Input Send Button - smaller on mobile */
  .chat-input-send {
    padding: var(--spacing-sm) var(--spacing-md);
    font-size: var(--text-sm);
    min-height: 40px;
  }

  /* Chat Message - full width on mobile */
  .chat-message-user,
  .chat-message-assistant {
    max-width: 95%;
  }
}

@media (min-width: 481px) and (max-width: 768px) {
  /* Chat Modal - adjusted for tablets */
  .chat-modal {
    width: calc(100% - var(--spacing-xl));
    max-width: 450px;
    margin: var(--spacing-md);
  }
}
</file>

