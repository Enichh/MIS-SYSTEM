<file path="app/login/page.tsx">
"use client";

import { useState } from "react";
import { useRouter } from "next/navigation";
import { Mail, Lock, Eye, EyeOff, Building2, AlertCircle } from "lucide-react";
import "../styles/login.css";

export default function LoginPage() {
  const router = useRouter();

  const [email, setEmail] = useState("");
  const [password, setPassword] = useState("");
  const [showPassword, setShowPassword] = useState(false);
  const [error, setError] = useState("");
  const [isLoading, setIsLoading] = useState(false);
  const [fieldErrors, setFieldErrors] = useState<{
    email?: string;
    password?: string;
  }>({});

  const validateForm = (): boolean => {
    const errors: { email?: string; password?: string } = {};

    if (!email) {
      errors.email = "Email is required";
    } else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      errors.email = "Please enter a valid email address";
    }

    if (!password) {
      errors.password = "Password is required";
    } else if (password.length < 8) {
      errors.password = "Password must be at least 8 characters";
    }

    setFieldErrors(errors);
    return Object.keys(errors).length === 0;
  };

  const handleSubmit = async (e: React.FormEvent) => {
    e.preventDefault();
    setError("");

    if (!validateForm()) {
      return;
    }

    setIsLoading(true);

    try {
      // First verify password
      const response = await fetch("/api/auth/login", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          email: email.trim(),
          password,
        }),
      });

      const data = await response.json();

      if (!data.success) {
        setError(data.error || "Invalid email or password");
        return;
      }

      // Password is correct, create temporary token and send verification code
      const tempToken = JSON.stringify({
        email: email.trim(),
        password,
      });

      const codeResponse = await fetch("/api/auth/send-code", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          email: email.trim(),
          type: "login",
          tempToken,
        }),
      });

      const codeData = await codeResponse.json();

      if (codeData.success) {
        // Redirect to verification page
        router.push(
          `/verify-code?email=${encodeURIComponent(email.trim())}&type=login&tempToken=${encodeURIComponent(tempToken)}`,
        );
      } else {
        setError(codeData.error || "Failed to send verification code");
      }
    } catch (err) {
      setError("An unexpected error occurred. Please try again.");
    } finally {
      setIsLoading(false);
    }
  };

  return (
    <div className="login-page" data-theme="dark">
      <div className="login-container">
        <div className="login-header">
          <div className="login-logo">
            <Building2 className="login-logo-icon" />
          </div>
          <h1>Admin Login</h1>
          <p>Sign in to access the Management Information System</p>
        </div>

        {error && (
          <div className="login-error" role="alert">
            <AlertCircle className="login-error-icon" />
            <span>{error}</span>
          </div>
        )}

        <form className="login-form" onSubmit={handleSubmit} noValidate>
          <div className="login-form-field">
            <label htmlFor="email" className="login-form-label">
              Email Address<span className="required">*</span>
            </label>
            <div className="login-input-wrapper">
              <Mail className="login-input-icon" />
              <input
                id="email"
                type="email"
                className={`login-input ${fieldErrors.email ? "login-input-error" : ""}`}
                placeholder="admin@example.com"
                value={email}
                onChange={(e) => {
                  setEmail(e.target.value);
                  if (fieldErrors.email) {
                    setFieldErrors((prev) => ({ ...prev, email: undefined }));
                  }
                }}
                disabled={isLoading}
                autoComplete="email"
                autoFocus
                required
              />
            </div>
            {fieldErrors.email && (
              <span className="form-error">{fieldErrors.email}</span>
            )}
          </div>

          <div className="login-form-field">
            <label htmlFor="password" className="login-form-label">
              Password<span className="required">*</span>
            </label>
            <div className="login-input-wrapper">
              <Lock className="login-input-icon" />
              <input
                id="password"
                type={showPassword ? "text" : "password"}
                className={`login-input ${fieldErrors.password ? "login-input-error" : ""}`}
                placeholder="Enter your password"
                value={password}
                onChange={(e) => {
                  setPassword(e.target.value);
                  if (fieldErrors.password) {
                    setFieldErrors((prev) => ({
                      ...prev,
                      password: undefined,
                    }));
                  }
                }}
                disabled={isLoading}
                autoComplete="current-password"
                required
              />
              <button
                type="button"
                className="login-password-toggle"
                onClick={() => setShowPassword(!showPassword)}
                disabled={isLoading}
                aria-label={showPassword ? "Hide password" : "Show password"}
              >
                {showPassword ? <EyeOff /> : <Eye />}
              </button>
            </div>
            {fieldErrors.password && (
              <span className="form-error">{fieldErrors.password}</span>
            )}
          </div>

          <div className="login-options">
            <a href="/forgot-password" className="login-forgot">
              Forgot password?
            </a>
          </div>

          <button
            type="submit"
            className={`login-submit ${isLoading ? "login-submit-loading" : ""}`}
            disabled={isLoading}
          >
            {isLoading ? "Signing in..." : "Sign In"}
          </button>
        </form>

        <div className="login-footer">
          <p>Admin access only. Unauthorized attempts are logged.</p>
          <p style={{ marginTop: "var(--spacing-sm)" }}>
            Need an account?{" "}
            <a href="/signup" className="login-forgot">
              Create admin account
            </a>
          </p>
        </div>

        <div className="login-security-info">
          <Building2 />
          <span>Secured with enterprise-grade encryption</span>
        </div>
      </div>
    </div>
  );
}
</file>

<file path="app/styles/login.css">
/* Login Page Styles
 * Modern dark theme admin login page following best practices
 */

.login-page {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(
    135deg,
    var(--color-background) 0%,
    var(--color-background-tertiary) 50%,
    var(--color-background) 100%
  );
  padding: var(--spacing-md);
  position: relative;
  overflow: hidden;
}

.login-page::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background:
    radial-gradient(
      circle at 20% 80%,
      hsl(25 72% 51% / 0.08) 0%,
      transparent 50%
    ),
    radial-gradient(
      circle at 80% 20%,
      hsl(25 72% 51% / 0.05) 0%,
      transparent 50%
    );
  pointer-events: none;
}

.login-container {
  width: 100%;
  max-width: 440px;
  background: linear-gradient(
    145deg,
    var(--color-background-secondary) 0%,
    var(--color-background-tertiary) 100%
  );
  border-radius: 20px;
  box-shadow:
    0 25px 50px -12px rgba(0, 0, 0, 0.5),
    0 0 0 1px var(--color-border-light);
  padding: var(--spacing-2xl);
  border: 1px solid var(--color-border);
  position: relative;
  backdrop-filter: blur(10px);
}

.login-header {
  text-align: center;
  margin-bottom: var(--spacing-xl);
}

.login-header h1 {
  font-size: var(--text-2xl);
  font-weight: var(--font-weight-bold);
  color: var(--color-text);
  margin-bottom: var(--spacing-sm);
  letter-spacing: -0.025em;
}

.login-header p {
  font-size: var(--text-base);
  color: var(--color-text-secondary);
  line-height: 1.6;
}

.login-logo {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--spacing-sm);
  margin-bottom: var(--spacing-lg);
  position: relative;
}

.login-logo-icon {
  width: 56px;
  height: 56px;
  color: var(--color-primary);
  filter: drop-shadow(0 0 20px hsl(25 72% 51% / 0.3));
  animation: pulse 3s ease-in-out infinite;
}

@keyframes pulse {
  0%,
  100% {
    transform: scale(1);
    filter: drop-shadow(0 0 20px hsl(25 72% 51% / 0.3));
  }
  50% {
    transform: scale(1.05);
    filter: drop-shadow(0 0 30px hsl(25 72% 51% / 0.5));
  }
}

.login-form {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-md);
}

.login-form-field {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-xs);
}

.login-form-label {
  font-size: var(--text-sm);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text);
  margin-bottom: var(--spacing-xs);
  letter-spacing: 0.025em;
}

.login-form-label .required {
  color: var(--color-primary);
  margin-left: 0.25rem;
}

.login-input-wrapper {
  position: relative;
}

.login-input-icon {
  position: absolute;
  left: var(--spacing-md);
  top: 50%;
  transform: translateY(-50%);
  color: var(--color-text-muted);
  width: 20px;
  height: 20px;
  pointer-events: none;
  transition: color var(--transition-fast);
}

.login-input {
  width: 100%;
  padding: var(--spacing-md) var(--spacing-md) var(--spacing-md) 44px;
  border: 2px solid var(--color-border);
  border-radius: 12px;
  background-color: var(--color-background-tertiary);
  color: var(--color-text);
  font-size: var(--text-base);
  font-family: var(--font-sans);
  transition: all var(--transition-base);
}

.login-input:hover {
  border-color: var(--color-border-light);
  background-color: var(--color-background-secondary);
}

.login-input:focus {
  outline: none;
  border-color: var(--color-primary);
  background-color: var(--color-background-secondary);
  box-shadow: 0 0 0 3px hsl(25 72% 51% / 0.15);
}

.login-input::placeholder {
  color: var(--color-text-muted);
}

[data-theme="dark"] .login-input::placeholder {
  color: oklch(0.75 0.02 240);
}

.login-input:focus + .login-input-icon {
  color: var(--color-primary);
}

.login-input:disabled {
  opacity: 0.5;
  cursor: not-allowed;
  background-color: var(--color-background-tertiary);
}

.login-input-error {
  border-color: var(--color-error) !important;
  box-shadow: 0 0 0 3px hsl(25 72% 51% / 0.15) !important;
  animation: shake 0.3s ease-in-out;
}

@keyframes shake {
  0%,
  100% {
    transform: translateX(0);
  }
  25% {
    transform: translateX(-4px);
  }
  75% {
    transform: translateX(4px);
  }
}

.login-password-toggle {
  position: absolute;
  right: var(--spacing-md);
  top: 50%;
  transform: translateY(-50%);
  background: none;
  border: none;
  cursor: pointer;
  color: var(--color-text-muted);
  padding: var(--spacing-xs);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all var(--transition-fast);
  border-radius: 6px;
}

.login-password-toggle:hover {
  color: var(--color-primary);
  background-color: hsl(25 72% 51% / 0.1);
}

.login-password-toggle:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.login-password-toggle svg {
  width: 20px;
  height: 20px;
}

.login-options {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: var(--spacing-xs);
}

.login-remember {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  cursor: pointer;
  font-size: var(--text-sm);
  color: var(--color-text-secondary);
  user-select: none;
}

.login-remember input[type="checkbox"] {
  width: 18px;
  height: 18px;
  accent-color: var(--color-primary);
  cursor: pointer;
}

.login-forgot {
  font-size: var(--text-sm);
  color: var(--color-primary);
  text-decoration: none;
  transition: color var(--transition-fast);
}

.login-forgot:hover {
  color: var(--color-primary-hover);
  text-decoration: underline;
}

.login-error {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  padding: var(--spacing-sm) var(--spacing-md);
  background: linear-gradient(
    135deg,
    hsl(25 72% 51% / 0.15) 0%,
    hsl(25 72% 51% / 0.08) 100%
  );
  border: 1px solid hsl(25 72% 51% / 0.3);
  border-radius: 10px;
  color: hsl(25 85% 65%);
  font-size: var(--text-sm);
  font-weight: var(--font-weight-medium);
  animation: slideIn 0.3s ease-out;
}

@keyframes slideIn {
  from {
    opacity: 0;
    transform: translateY(-8px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.login-error-icon {
  width: 18px;
  height: 18px;
  flex-shrink: 0;
}

.login-submit {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--spacing-sm);
  width: 100%;
  padding: var(--spacing-md);
  margin-top: var(--spacing-sm);
  background: linear-gradient(
    135deg,
    var(--color-primary) 0%,
    var(--color-primary-hover) 100%
  );
  color: white;
  border: none;
  border-radius: 12px;
  font-size: var(--text-base);
  font-weight: var(--font-weight-semibold);
  cursor: pointer;
  transition: all var(--transition-base);
  min-height: 48px;
  box-shadow: 0 4px 14px hsl(25 72% 51% / 0.3);
  position: relative;
  overflow: hidden;
}

.login-submit::before {
  content: "";
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(
    90deg,
    transparent,
    rgba(255, 255, 255, 0.2),
    transparent
  );
  transition: left 0.5s;
}

.login-submit:hover:not(:disabled)::before {
  left: 100%;
}

.login-submit:hover:not(:disabled) {
  transform: translateY(-2px);
  box-shadow: 0 6px 20px hsl(25 72% 51% / 0.4);
}

.login-submit:active:not(:disabled) {
  transform: translateY(0);
}

.login-submit:disabled {
  opacity: 0.6;
  cursor: not-allowed;
  box-shadow: none;
}

.login-submit-loading {
  position: relative;
  color: transparent;
}

.login-submit-loading::after {
  content: "";
  position: absolute;
  width: 20px;
  height: 20px;
  border: 2px solid rgba(255, 255, 255, 0.3);
  border-top-color: white;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.login-footer {
  margin-top: var(--spacing-xl);
  text-align: center;
  font-size: var(--text-sm);
  color: var(--color-text-secondary);
  line-height: 1.6;
}

.login-security-info {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--spacing-xs);
  margin-top: var(--spacing-lg);
  padding-top: var(--spacing-lg);
  border-top: 1px solid var(--color-border-light);
  font-size: var(--text-xs);
  color: var(--color-text-muted);
  background: linear-gradient(
    180deg,
    transparent 0%,
    hsl(25 72% 51% / 0.03) 100%
  );
  padding: var(--spacing-md);
  border-radius: 8px;
}

.login-security-info svg {
  width: 16px;
  height: 16px;
  color: var(--color-primary);
}

/* Rate Limit Warning */
.login-rate-limit {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  padding: var(--spacing-sm) var(--spacing-md);
  background-color: hsl(38 92% 50% / 0.1);
  border: 1px solid hsl(38 92% 50% / 0.2);
  border-radius: 8px;
  color: hsl(38 80% 35%);
  font-size: var(--text-sm);
  font-weight: var(--font-weight-medium);
}

.login-rate-limit-icon {
  width: 18px;
  height: 18px;
  flex-shrink: 0;
}

/* Success Notification */
.login-success {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  padding: var(--spacing-sm) var(--spacing-md);
  background: linear-gradient(
    135deg,
    hsl(142 60% 55% / 0.15) 0%,
    hsl(142 60% 55% / 0.08) 100%
  );
  border: 1px solid hsl(142 60% 55% / 0.3);
  border-radius: 10px;
  color: hsl(142 70% 60%);
  font-size: var(--text-sm);
  font-weight: var(--font-weight-medium);
  animation: slideIn 0.3s ease-out;
}

.login-success-icon {
  width: 18px;
  height: 18px;
  flex-shrink: 0;
}

/* Info Notification */
.login-info {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  padding: var(--spacing-sm) var(--spacing-md);
  background-color: hsl(220 60% 55% / 0.1);
  border: 1px solid hsl(220 60% 55% / 0.2);
  border-radius: 8px;
  color: hsl(220 60% 40%);
  font-size: var(--text-sm);
  font-weight: var(--font-weight-medium);
}

.login-info-icon {
  width: 18px;
  height: 18px;
  flex-shrink: 0;
}

/* Form Error (field-level) */
.form-error {
  margin-top: 0.5rem;
  font-size: 0.8125rem;
  color: var(--color-error);
  font-weight: 600;
  display: flex;
  align-items: center;
  gap: 0.375rem;
  animation: slideDown 0.2s ease;
}

/* Centered Content */
.login-center {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: var(--spacing-sm);
}

/* Stacked Actions */
.login-actions-stack {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-md);
}

/* Back Button */
.login-back-button {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--spacing-xs);
  margin: 0 auto;
  background: none;
  border: none;
  cursor: pointer;
  font-size: var(--text-sm);
  color: var(--color-primary);
  text-decoration: none;
  transition: color var(--transition-fast);
  padding: var(--spacing-xs);
}

.login-back-button:hover {
  color: var(--color-primary-hover);
  text-decoration: underline;
}

.login-back-button svg {
  width: 16px;
  height: 16px;
}

/* Secondary Button Variant */
.login-submit-secondary {
  background-color: var(--color-background-secondary);
  color: var(--color-text);
  border: 1px solid var(--color-border);
}

.login-submit-secondary:hover:not(:disabled) {
  background-color: var(--color-background-tertiary);
  transform: translateY(-1px);
}

/* Icon Color Variants */
.login-logo-icon-success {
  color: var(--color-success);
}

.login-logo-icon-error {
  color: var(--color-error);
}

.login-logo-icon-primary {
  color: var(--color-primary);
}

/* Header Color Variants */
.login-header-success {
  color: var(--color-success);
}

.login-header-error {
  color: var(--color-error);
}

.login-header-primary {
  color: var(--color-primary);
}

/* Spinner Animation */
.login-spinner {
  animation: spin 1s linear infinite;
}

/* Large Icon */
.login-large-icon {
  width: 32px;
  height: 32px;
}

/* Footer Text */
.login-footer-text {
  margin-bottom: var(--spacing-md);
  font-size: var(--text-sm);
  color: var(--color-text-secondary);
}

/* Dark Mode Overrides */
[data-theme="dark"] .login-page {
  background: linear-gradient(
    135deg,
    var(--color-background) 0%,
    var(--color-background-tertiary) 50%,
    var(--color-background) 100%
  );
}

[data-theme="dark"] .login-container {
  background: linear-gradient(
    145deg,
    var(--color-background-secondary) 0%,
    var(--color-background-tertiary) 100%
  );
  border-color: var(--color-border);
}

[data-theme="dark"] .login-input {
  background-color: var(--color-background-tertiary);
  border-color: var(--color-border);
  color: var(--color-text);
}

[data-theme="dark"] .login-input:hover,
[data-theme="dark"] .login-input:focus {
  border-color: var(--color-primary);
  background-color: var(--color-background-secondary);
}

[data-theme="dark"] .login-error {
  background: linear-gradient(
    135deg,
    hsl(25 72% 51% / 0.15) 0%,
    hsl(25 72% 51% / 0.08) 100%
  );
  color: hsl(25 85% 65%);
}

[data-theme="dark"] .login-rate-limit {
  background: linear-gradient(
    135deg,
    hsl(38 92% 50% / 0.15) 0%,
    hsl(38 92% 50% / 0.08) 100%
  );
  color: hsl(38 85% 55%);
}

[data-theme="dark"] .login-success {
  background: linear-gradient(
    135deg,
    hsl(142 60% 55% / 0.15) 0%,
    hsl(142 60% 55% / 0.08) 100%
  );
  color: hsl(142 70% 60%);
}

[data-theme="dark"] .login-info {
  background: linear-gradient(
    135deg,
    hsl(220 60% 55% / 0.15) 0%,
    hsl(220 60% 55% / 0.08) 100%
  );
  color: hsl(220 70% 60%);
}

[data-theme="dark"] .login-submit-secondary {
  background-color: var(--color-background-tertiary);
  color: var(--color-text);
}

[data-theme="dark"] .login-submit-secondary:hover:not(:disabled) {
  background-color: var(--color-background-secondary);
}

/* Responsive */
@media (max-width: 480px) {
  .login-container {
    padding: var(--spacing-xl);
    border-radius: 12px;
  }

  .login-header h1 {
    font-size: var(--text-xl);
  }

  .login-options {
    flex-direction: column;
    gap: var(--spacing-sm);
    align-items: flex-start;
  }
}

/* Accessibility */
@media (prefers-reduced-motion: reduce) {
  .login-submit,
  .login-input,
  .login-password-toggle,
  .login-forgot {
    transition: none;
  }

  .login-submit-loading::after {
    animation: none;
    border-top-color: transparent;
    border-color: rgba(255, 255, 255, 0.5);
  }
}

/* Focus visible for keyboard navigation */
.login-submit:focus-visible,
.login-password-toggle:focus-visible,
.login-forgot:focus-visible {
  outline: none;
  box-shadow: var(--focus-ring);
}
