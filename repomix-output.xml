<file path="app/components/ReportDrawer/ReportDrawer.css">
/* Report Drawer Component Styles
 * Extends existing chat styles with report-specific styles
 */

/* Report Drawer Container */
.report-drawer {
  display: flex;
  flex-direction: column;
  height: 100%;
  background-color: var(--color-background-secondary);
  border-radius: 12px;
  overflow: hidden;
}

/* Report Drawer Header */
.report-drawer-header {
  background-color: var(--color-primary);
  color: var(--color-background);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.report-drawer-header h3 {
  color: var(--color-background);
  margin: 0;
}

.report-drawer-header-actions {
  display: flex;
  align-items: center;
  gap: var(--spacing-md);
}

.report-drawer-header .chat-modal-delete {
  color: var(--color-background);
}

.report-drawer-header .chat-modal-delete:hover {
  background-color: rgba(255, 255, 255, 0.1);
}

/* Report Detail Toggle */
.report-detail-toggle {
  display: flex;
  align-items: center;
}

.report-toggle-label {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  cursor: pointer;
  font-size: var(--text-sm);
  color: var(--color-background);
  user-select: none;
}

.report-toggle-label:has(.report-toggle-checkbox:disabled) {
  opacity: 0.6;
  cursor: not-allowed;
}

.report-toggle-checkbox {
  width: 16px;
  height: 16px;
  cursor: pointer;
  accent-color: var(--color-background);
}

.report-toggle-checkbox:disabled {
  cursor: not-allowed;
}

.report-toggle-text {
  font-weight: var(--font-weight-medium);
}

/* Quick Report Actions */
.report-quick-actions {
  padding: var(--spacing-lg);
  background-color: var(--color-background);
  border-radius: 8px;
  margin-top: var(--spacing-lg);
  border: 1px solid var(--color-border);
}

.report-quick-actions-title {
  font-size: var(--text-sm);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-secondary);
  margin: 0 0 var(--spacing-md) 0;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.report-quick-actions-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--spacing-sm);
}

@media (max-width: 480px) {
  .report-quick-actions-grid {
    grid-template-columns: 1fr;
  }
}

/* Quick Action Button */
.report-quick-action-btn {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  padding: var(--spacing-md);
  background-color: var(--color-background-secondary);
  border: 1px solid var(--color-border);
  border-radius: 8px;
  cursor: pointer;
  transition: var(--transition-base);
  font-family: var(--font-family);
  font-size: var(--text-sm);
  color: var(--color-text);
  text-align: left;
}

.report-quick-action-btn:hover {
  background-color: var(--color-primary-light);
  border-color: var(--color-primary);
  transform: translateY(-1px);
  box-shadow: var(--shadow-sm);
}

.report-quick-action-btn:focus {
  outline: none;
  box-shadow: var(--focus-ring);
}

.report-quick-action-btn:active {
  transform: translateY(0);
}

.report-quick-action-btn:disabled {
  opacity: 0.6;
  cursor: not-allowed;
  transform: none;
  box-shadow: none;
}

.report-quick-action-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 32px;
  height: 32px;
  background-color: var(--color-primary);
  color: var(--color-background);
  border-radius: 6px;
  flex-shrink: 0;
}

.report-quick-action-label {
  font-weight: var(--font-weight-medium);
}

/* Report Preview */
.report-preview {
  background-color: var(--color-background);
  border: 1px solid var(--color-border);
  border-radius: 8px;
  padding: var(--spacing-lg);
  margin: var(--spacing-md) 0;
  animation: fadeIn var(--transition-base);
}

.report-preview-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-sm);
  flex-wrap: wrap;
  gap: var(--spacing-sm);
}

.report-preview-title {
  font-size: var(--text-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text);
  margin: 0;
}

.report-preview-actions {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
}

.report-preview-type {
  font-size: var(--text-xs);
  font-weight: var(--font-weight-medium);
  color: var(--color-primary);
  background-color: var(--color-primary-light);
  padding: var(--spacing-xs) var(--spacing-sm);
  border-radius: 4px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.report-pdf-download-btn {
  padding: var(--spacing-xs) var(--spacing-md);
  background-color: var(--color-primary);
  color: var(--color-background);
  border: none;
  border-radius: 4px;
  font-size: var(--text-xs);
  font-weight: var(--font-weight-medium);
  cursor: pointer;
  transition: var(--transition-base);
  font-family: var(--font-family);
}

.report-pdf-download-btn:hover:not(:disabled) {
  background-color: var(--color-primary-dark);
  transform: translateY(-1px);
  box-shadow: var(--shadow-sm);
}

.report-pdf-download-btn:focus {
  outline: none;
  box-shadow: var(--focus-ring);
}

.report-pdf-download-btn:disabled {
  opacity: 0.6;
  cursor: not-allowed;
  transform: none;
  box-shadow: none;
}

.report-preview-meta {
  font-size: var(--text-sm);
  color: var(--color-text-secondary);
  margin-bottom: var(--spacing-md);
  padding-bottom: var(--spacing-md);
  border-bottom: 1px solid var(--color-border);
}

/* Report Metrics */
.report-preview-metrics {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
  gap: var(--spacing-md);
}

.report-preview-metric {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-xs);
  padding: var(--spacing-md);
  background-color: var(--color-background-secondary);
  border-radius: 6px;
}

.report-preview-metric-label {
  font-size: var(--text-xs);
  color: var(--color-text-secondary);
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.report-preview-metric-value {
  font-size: var(--text-xl);
  font-weight: var(--font-weight-bold);
  color: var(--color-text);
}

.report-preview-metric-unit {
  font-size: var(--text-sm);
  font-weight: var(--font-weight-normal);
  color: var(--color-text-secondary);
  margin-left: var(--spacing-xs);
}

.report-preview-metric-trend {
  font-size: var(--text-lg);
  font-weight: var(--font-weight-bold);
}

.report-preview-metric-trend-up {
  color: var(--color-success);
}

.report-preview-metric-trend-down {
  color: var(--color-error);
}

.report-preview-metric-trend-stable {
  color: var(--color-text-secondary);
}

/* Mobile Responsive Adjustments */
@media (max-width: 768px) {
  .report-quick-actions {
    padding: var(--spacing-md);
  }

  .report-quick-action-btn {
    padding: var(--spacing-sm);
  }

  .report-preview {
    padding: var(--spacing-md);
  }

  .report-preview-title {
    font-size: var(--text-base);
  }

  .report-preview-metrics {
    grid-template-columns: repeat(2, 1fr);
  }

  .report-preview-metric-value {
    font-size: var(--text-lg);
  }
}

@media (max-width: 480px) {
  .report-preview-metrics {
    grid-template-columns: 1fr;
  }
}

/* Dark Mode Overrides for ReportDrawer */
[data-theme="dark"] .report-drawer {
  background-color: var(--color-background-secondary);
}

[data-theme="dark"] .report-quick-actions {
  background-color: var(--color-background-tertiary);
  border-color: var(--color-border);
}

[data-theme="dark"] .report-quick-actions-title {
  color: var(--color-text);
}

[data-theme="dark"] .report-quick-action-btn {
  background-color: var(--color-background);
  border-color: var(--color-border);
  color: var(--color-text);
}

[data-theme="dark"] .report-quick-action-btn:hover {
  background-color: var(--color-background-secondary);
  border-color: var(--color-primary);
}

[data-theme="dark"] .report-preview {
  background-color: var(--color-background-tertiary);
  border-color: var(--color-border);
}

[data-theme="dark"] .report-preview-title {
  color: var(--color-text);
}

[data-theme="dark"] .report-preview-type {
  background-color: var(--color-primary-light, rgba(59, 130, 246, 0.15));
  color: var(--color-primary);
}

[data-theme="dark"] .report-preview-meta {
  color: var(--color-text-secondary);
  border-color: var(--color-border);
}

[data-theme="dark"] .report-preview-metric {
  background-color: var(--color-background);
}

[data-theme="dark"] .report-preview-metric-label {
  color: var(--color-text-secondary);
}

[data-theme="dark"] .report-preview-metric-value {
  color: var(--color-text);
}

[data-theme="dark"] .report-preview-metric-unit {
  color: var(--color-text-secondary);
}
