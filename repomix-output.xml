          searchSec: Number((searchTime / 1000).toFixed(2)),
          aiSec: Number((aiTime / 1000).toFixed(2)),
        },
      },
    }, {
      status: 200,
      headers: {
        'Content-Type': 'application/json',
        'Cache-Control': 'private, max-age=60, stale-while-revalidate=300',
