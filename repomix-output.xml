/* Verification Code Page Styles
 * Modern dark theme verification page following best practices
 */

.verify-page {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(
    135deg,
    var(--color-background) 0%,
    var(--color-background-tertiary) 50%,
    var(--color-background) 100%
  );
  padding: var(--spacing-md);
  position: relative;
  overflow: hidden;
}

.verify-page::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background:
    radial-gradient(
      circle at 20% 80%,
      hsl(25 72% 51% / 0.08) 0%,
      transparent 50%
    ),
    radial-gradient(
      circle at 80% 20%,
      hsl(25 72% 51% / 0.05) 0%,
      transparent 50%
    );
  pointer-events: none;
}

.verify-container {
  width: 100%;
  max-width: 440px;
  background: linear-gradient(
    145deg,
    var(--color-background-secondary) 0%,
    var(--color-background-tertiary) 100%
  );
  border-radius: 20px;
  box-shadow:
    0 25px 50px -12px rgba(0, 0, 0, 0.5),
    0 0 0 1px var(--color-border-light);
  padding: var(--spacing-2xl);
  border: 1px solid var(--color-border);
  position: relative;
  backdrop-filter: blur(10px);
}

.verify-header {
  text-align: center;
  margin-bottom: var(--spacing-xl);
}

.verify-header h1 {
  font-size: var(--text-2xl);
  font-weight: var(--font-weight-bold);
  color: var(--color-text);
  margin-bottom: var(--spacing-sm);
  letter-spacing: -0.025em;
}

.verify-header p {
  font-size: var(--text-base);
  color: var(--color-text-secondary);
  line-height: 1.6;
}

.verify-logo {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--spacing-sm);
  margin-bottom: var(--spacing-lg);
  position: relative;
}

.verify-logo-icon {
  width: 56px;
  height: 56px;
  color: var(--color-primary);
  filter: drop-shadow(0 0 20px hsl(25 72% 51% / 0.3));
  animation: pulse 3s ease-in-out infinite;
}

.verify-logo-icon-success {
  color: var(--color-success);
  filter: drop-shadow(0 0 20px hsl(142 60% 55% / 0.3));
}

@keyframes pulse {
  0%,
  100% {
    transform: scale(1);
    filter: drop-shadow(0 0 20px hsl(25 72% 51% / 0.3));
  }
  50% {
    transform: scale(1.05);
    filter: drop-shadow(0 0 30px hsl(25 72% 51% / 0.5));
  }
}

.verify-code-inputs {
  display: flex;
  gap: var(--spacing-sm);
  justify-content: center;
  margin-bottom: var(--spacing-xl);
}

.verify-code-input {
  width: 48px;
  height: 56px;
  padding: 0;
  border: 2px solid var(--color-border);
  border-radius: 12px;
  background-color: var(--color-background-tertiary);
  color: var(--color-text);
  font-size: var(--text-xl);
  font-weight: var(--font-weight-bold);
  text-align: center;
  font-family: var(--font-sans);
  transition: all var(--transition-base);
  caret-color: var(--color-primary);
}

.verify-code-input:hover {
  border-color: var(--color-border-light);
  background-color: var(--color-background-secondary);
}

.verify-code-input:focus {
  outline: none;
  border-color: var(--color-primary);
  background-color: var(--color-background-secondary);
  box-shadow: 0 0 0 3px hsl(25 72% 51% / 0.15);
  transform: translateY(-2px);
}

