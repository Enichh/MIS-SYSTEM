<file path="app/styles/modals.css">
/* Modal Components Module
 * Modal overlay, modal content, and HTML dialog element styling
 */

/* Modal Overlay */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(8px);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  animation: fadeIn 0.2s ease;
}

.modal-overlay.hidden {
  display: none;
}

/* Modal Content */
.modal {
  background-color: var(--color-background);
  border-radius: 16px;
  max-width: 500px;
  width: 90%;
  max-height: 90vh;
  overflow-y: auto;
  box-shadow: var(--shadow-xl);
  border: 1px solid var(--color-border-light);
  padding: var(--spacing-lg);
}

/* Modal Header */
.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 0 var(--spacing-sm) 0;
  margin-bottom: var(--spacing-sm);
  border-bottom: 1px solid var(--color-border-light);
}

.modal-header h3 {
  color: var(--color-text);
  font-weight: var(--font-weight-bold);
  font-size: var(--text-2xl);
  letter-spacing: -0.025em;
  line-height: 1.2;
}

/* Modal Body */
.modal-body {
  padding: var(--spacing-md) 0 var(--spacing-lg) 0;
  color: var(--color-text);
}

/* HTML Dialog Element Styling */
dialog {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  margin: 0;
  max-width: 90vw;
  max-height: 90vh;
  overflow-y: auto;
  opacity: 0;
  transition:
    opacity var(--transition-slow),
    transform var(--transition-slow);
}

dialog[open] {
  opacity: 1;
}

dialog::backdrop {
  background-color: rgba(0, 0, 0, 0.5);
  backdrop-filter: blur(8px);
  opacity: 0;
  transition: opacity var(--transition-slow);
}

dialog[open]::backdrop {
  opacity: 1;
}

/* Glassmorphism effect for modals in dark mode */
[data-theme="dark"] dialog {
  background: linear-gradient(
    135deg,
    var(--color-background-secondary) 0%,
    var(--color-background-tertiary) 100%
  );
  border: 1px solid var(--color-border);
  box-shadow:
    0 25px 50px -12px rgba(0, 0, 0, 0.5),
    0 0 0 1px rgba(255, 255, 255, 0.05) inset;
}

[data-theme="light"] dialog {
  background: linear-gradient(
    135deg,
    var(--color-background-secondary) 0%,
    var(--color-background-tertiary) 100%
  );
  border: 1px solid var(--color-border-light);
  box-shadow:
    0 25px 50px -12px rgba(0, 0, 0, 0.15),
    0 0 0 1px rgba(0, 0, 0, 0.02) inset;
}

/* Semantic Modal Component Classes (Radix Dialog) */
.modal-overlay {
  position: fixed;
  inset: 0;
  z-index: 1000;
  background-color: rgba(0, 0, 0, 0.4);
  backdrop-filter: blur(4px);
}

.modal-content {
  position: fixed;
  left: 50%;
  top: 50%;
  z-index: 1001;
  display: grid;
  width: 100%;
  max-width: 32rem;
  max-height: 85vh;
  overflow-y: auto;
  transform: translate(-50%, -50%);
  gap: 1rem;
  border: 2px solid var(--color-border);
  background-color: var(--color-background);
  backdrop-filter: blur(24px);
  padding: 1.5rem;
  box-shadow: var(--shadow-2xl);
  border-radius: 1.5rem;
}

/* Dark Mode Overrides for Modal Content */
[data-theme="dark"] .modal-content {
  background-color: var(--color-background-secondary);
  border-color: var(--color-border);
  box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
}

[data-theme="dark"] .modal-header {
  border-color: var(--color-border);
}

[data-theme="dark"] .modal-title {
  color: var(--color-text);
}

[data-theme="dark"] .modal-description {
  color: var(--color-text-secondary);
}

[data-theme="dark"] .modal-close {
  color: var(--color-text-muted);
}

[data-theme="dark"] .modal-close:hover {
  color: var(--color-text);
  background-color: var(--color-background-tertiary);
}

/* Dark Mode for form elements inside modals */
[data-theme="dark"] .modal-content .form-field {
  background-color: transparent !important;
}

[data-theme="dark"] .modal-content .form-label {
  color: var(--color-text) !important;
}

[data-theme="dark"] .modal-content .form-label .required {
  color: var(--color-primary) !important;
}

[data-theme="dark"] .modal-content .input {
  background-color: var(--color-background-tertiary) !important;
  border-color: var(--color-border) !important;
  color: var(--color-text) !important;
}

[data-theme="dark"] .modal-content .input::placeholder {
  color: oklch(0.75 0.02 240) !important;
}

[data-theme="dark"] .modal-content .textarea {
  background-color: var(--color-background-tertiary) !important;
  border-color: var(--color-border) !important;
  color: var(--color-text) !important;
}

[data-theme="dark"] .modal-content .textarea::placeholder {
  color: oklch(0.75 0.02 240) !important;
}

[data-theme="dark"] .modal-content .select-trigger {
  background-color: var(--color-background-tertiary) !important;
  border-color: var(--color-border) !important;
  color: var(--color-text) !important;
}

[data-theme="dark"] .modal-content .form-error {
  color: var(--color-error) !important;
}

[data-theme="dark"] .modal-content .notification {
  background-color: var(--color-background-tertiary) !important;
  border-color: var(--color-border) !important;
}

.modal-close {
  position: absolute;
  right: 1rem;
  top: 1rem;
  border-radius: 0.75rem;
  opacity: 0.7;
  padding: 0.5rem;
  transition: all var(--transition-base);
}

.modal-close:hover {
  opacity: 1;
  background-color: var(--color-background-secondary);
  transform: scale(1.1);
}

.modal-close:focus-visible {
  outline: none;
  box-shadow: var(--focus-ring);
}

.modal-header {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  text-align: left;
}

.modal-title {
  font-size: 1.25rem;
  font-weight: var(--font-weight-semibold);
  line-height: 1;
  letter-spacing: -0.025em;
  color: var(--color-text);
}

.modal-description {
  font-size: 0.875rem;
  color: var(--color-text-muted);
  line-height: 1.6;
}

.modal-footer {
  display: flex;
  flex-direction: column-reverse;
  gap: 0.5rem;
}

@media (min-width: 640px) {
  .modal-footer {
    flex-direction: row;
    justify-content: flex-end;
  }
}

/* Enhanced Modal Responsiveness */
@media (max-width: 480px) {
  /* Modal Content - full width on mobile with small margins */
  .modal {
    width: calc(100% - var(--spacing-md));
    max-width: none;
    padding: var(--spacing-md);
    border-radius: 12px;
  }

  /* Modal Header - smaller font on mobile */
  .modal-header h3 {
    font-size: var(--text-xl);
  }

  /* Modal Body - reduced padding on mobile */
  .modal-body {
    padding: var(--spacing-sm) 0 var(--spacing-md) 0;
  }

  /* Modal Content - full width on mobile */
  .modal-content {
    width: calc(100% - var(--spacing-md));
    max-width: none;
    padding: var(--spacing-md);
    border-radius: 12px;
  }

  /* Modal Title - smaller font on mobile */
  .modal-title {
    font-size: 1.125rem;
  }

  /* Modal Close - touch-friendly size */
  .modal-close {
    width: 2rem;
    height: 2rem;
    min-width: 44px;
    min-height: 44px;
  }
}

@media (min-width: 481px) and (max-width: 768px) {
  /* Modal Content - adjusted for tablets */
  .modal {
    max-width: 450px;
  }

  .modal-content {
    max-width: 28rem;
  }
}

.sr-only {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border-width: 0;
}
</file>

