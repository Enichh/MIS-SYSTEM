    query = query.eq('assignedto', filters.assignedto as string);
  }
  if (filters.name) {
    const nameColumn = tableName === 'tasks' ? 'title' : 'name';
    query = query.ilike(nameColumn, `%${filters.name as string}%`);
  }
  if (filters.department) {
