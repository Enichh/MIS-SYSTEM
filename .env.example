# Supabase Configuration
# Get these from your Supabase project dashboard (https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here

# LongCat API (for AI knowledge queries)
LONGCAT_API_KEY=your_longcat_api_key_here

# Note: BGE-small-en-v1.5 embeddings now run locally via Transformer.js
# No external API key required for embeddings

# Optional: Webhook secret for securing auto-sync webhooks (production recommended)
# WEBHOOK_SECRET=your_webhook_secret_here
WEBHOOK_SECRET= 
