# Supabase Configuration
# Get these from your Supabase project dashboard (https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here

# LongCat API (for AI knowledge queries)
LONGCAT_API_KEY=your_longcat_api_key_here

# Note: BGE-small-en-v1.5 embeddings now run locally via Transformer.js
# No external API key required for embeddings

# Optional: Webhook secret for securing auto-sync webhooks (production recommended)
# WEBHOOK_SECRET=your_webhook_secret_here
WEBHOOK_SECRET=

# Encryption key for temporary token encryption (2FA flow)
# Generate a secure 32-byte key: openssl rand -base64 32
ENCRYPTION_KEY=your_encryption_key_here

# Gmail SMTP Configuration for sending verification emails
# GMAIL_EMAIL: Your Gmail address
# GMAIL_APP_PASSWORD: Your Gmail App Password (generate from Google Account > Security > 2-Step Verification > App Passwords)
GMAIL_EMAIL=your_gmail@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password
