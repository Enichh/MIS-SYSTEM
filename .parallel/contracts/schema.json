{
  "version": "1.0.0",
  "feature": "AI Reports with PDF Export",
  "freeze_phase": "hot",
  "description": "Add AI-powered report generation with chat interface and PDF export. Rename 'reporting' to 'reports' throughout the codebase.",
  "contracts": {
    "shared": {
      "exports": {
        "public": {
          "types": ["ReportType", "ReportData", "ReportConfig", "PDFExportOptions"],
          "functions": ["validateReportType", "buildReportQuery"],
          "constants": ["REPORT_TYPES", "DEFAULT_REPORT_CONFIG"]
        },
        "internal": ["aggregateReportMetrics", "sanitizeReportData"]
      }
    },
    "shared-services": {
      "imports_from_shared": ["ReportType", "ReportData", "ReportConfig", "validateReportType"],
      "exports": ["generateReportData"],
      "file_naming": "lib/services/reportService.ts"
    },
    "backend": {
      "imports_from_shared": ["ReportType", "ReportData", "ReportConfig", "generateReportData"],
      "exports": ["POST /api/reports/generate", "generateReportTool"]
    },
    "frontend-core": {
      "imports_from_shared": ["ReportType", "ReportData", "ReportConfig"],
      "exports": ["useReportChat", "ReportDrawer"]
    },
    "frontend-pdf": {
      "imports_from_shared": ["ReportData", "PDFExportOptions"],
      "exports": ["ReportPDF", "PDFDownloadButton"],
      "dependency": "@react-pdf/renderer"
    }
  },
  "dependency_graph": {
    "shared": { "depends_on": [], "blocks": ["shared-services", "backend", "frontend-core"] },
    "shared-services": { "depends_on": ["shared"], "blocks": ["backend"] },
    "backend": { "depends_on": ["shared-services"], "blocks": ["frontend-core"] },
    "frontend-core": { "depends_on": ["backend"], "blocks": ["frontend-pdf"] },
    "frontend-pdf": { "depends_on": ["frontend-core"], "blocks": [] }
  },
  "renames": [
    {
      "from": "reporting",
      "to": "reports",
      "files": [
        "app/components/NavigationLinks/NavigationLinks.tsx",
        "lib/context/NavigationContext.tsx",
        "app/page.tsx"
      ]
    }
  ],
  "new_dependencies": [
    {
      "package": "@react-pdf/renderer",
      "version": "^3.4.0",
      "purpose": "PDF generation from React components",
      "workstream": "frontend-pdf"
    }
  ]
}
