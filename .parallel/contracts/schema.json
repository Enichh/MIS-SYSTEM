{
  "version": "1.0.0",
  "feature": "Hybrid Sidebar + Mobile Drawer Navigation",
  "freeze_phase": "hot",
  "contracts": {
    "shared": {
      "exports": {
        "public": {
          "types": ["NavigationContextType", "NavigationState"],
          "constants": ["BREAKPOINT_MOBILE", "BREAKPOINT_TABLET", "SIDEBAR_WIDTH_DESKTOP", "DRAWER_WIDTH_MOBILE"],
          "functions": ["useNavigationContext", "NavigationProvider"]
        },
        "internal": ["getBreakpoint", "isMobile", "isDesktop"]
      },
      "schemas": {
        "NavigationContextType": {
          "type": "object",
          "properties": {
            "isDrawerOpen": { "type": "boolean" },
            "isMobile": { "type": "boolean" },
            "toggleDrawer": { "type": "function" },
            "closeDrawer": { "type": "function" }
          },
          "required": ["isDrawerOpen", "isMobile", "toggleDrawer", "closeDrawer"]
        },
        "NavigationState": {
          "type": "object",
          "properties": {
            "isDrawerOpen": { "type": "boolean" },
            "isMobile": { "type": "boolean" }
          },
          "required": ["isDrawerOpen", "isMobile"]
        }
      }
    },
    "components": {
      "imports_from_shared": ["NavigationContextType", "useNavigationContext", "NavigationProvider", "BREAKPOINT_MOBILE", "SIDEBAR_WIDTH_DESKTOP", "DRAWER_WIDTH_MOBILE"],
      "exports": {
        "public": {
          "components": ["Sidebar", "Drawer", "HamburgerButton"]
        },
        "internal": []
      },
      "allowed_internal_helpers": true,
      "file_naming": {
        "pattern": "app/components/{PascalName}/{PascalName}.tsx",
        "example": "app/components/Sidebar/Sidebar.tsx"
      }
    },
    "integration": {
      "imports_from_shared": ["NavigationProvider", "useNavigationContext"],
      "imports_from_components": ["Sidebar", "Drawer", "HamburgerButton"],
      "exports": {
        "public": []
      },
      "allowed_internal_helpers": true,
      "file_naming": {
        "pattern": "app/{path}/{filename}.{ext}",
        "example": "app/components/Header/Header.tsx"
      }
    }
  },
  "boundaries": {
    "shared_to_components": {
      "data_shape": "NavigationContextType, NavigationState",
      "state_management": "React Context API for navigation state",
      "responsive_logic": "Media query detection for mobile/desktop"
    },
    "shared_to_integration": {
      "data_shape": "NavigationProvider, useNavigationContext",
      "context_usage": "Wrap application with NavigationProvider",
      "hook_usage": "Consume navigation state in components"
    },
    "components_to_integration": {
      "component_usage": "Sidebar (desktop), Drawer (mobile), HamburgerButton (trigger)",
      "styling_approach": "CSS classes from app/styles/ (no inline styles)",
      "responsive_behavior": "CSS media queries for layout switching"
    }
  },
  "dependency_graph": {
    "shared": {
      "depends_on": [],
      "blocks": ["components", "integration"]
    },
    "components": {
      "depends_on": ["shared"],
      "blocks": ["integration"]
    },
    "integration": {
      "depends_on": ["shared", "components"],
      "blocks": []
    }
  },
  "best_practices": {
    "css_responsive": {
      "breakpoints": "Mobile: < 768px, Desktop: >= 768px",
      "sidebar_width": "240-280px on desktop using CSS max() function",
      "drawer_width": "280px on mobile with slide-in animation",
      "transitions": "CSS transitions for smooth drawer open/close (300ms ease)",
      "media_queries": "Use @media (max-width: 768px) for mobile breakpoint"
    },
    "react_patterns": {
      "state_management": "Use React Context API for navigation state (useState, useEffect)",
      "responsive_detection": "Use window.matchMedia or useEffect with resize listener",
      "accessibility": "ARIA labels, focus management, keyboard navigation for drawer",
      "no_dom_manipulation": "Use React state instead of classList, getElementById"
    },
    "layout_architecture": {
      "desktop_layout": "CSS Grid with persistent sidebar on left, main content on right",
      "mobile_layout": "Overlay drawer triggered by hamburger, backdrop for click-to-close",
      "css_grid": "Use grid-template-areas for responsive layout switching",
      "container_queries": "Consider @container for component-level responsiveness"
    }
  },
  "codebase_impact": {
    "files_to_modify": [
      "app/styles/navigation.css - Add sidebar/drawer styles, responsive breakpoints",
      "app/styles/utilities.css - Add responsive utility classes if needed",
      "app/components/Navigation/Navigation.tsx - DEPRECATED: Replace with Sidebar/Drawer",
      "app/components/Header/Header.tsx - Add HamburgerButton for mobile",
      "app/layout.tsx - Wrap with NavigationProvider",
      "app/page.tsx - Update layout structure for sidebar/drawer integration"
    ],
    "files_to_create": [
      "app/components/Sidebar/Sidebar.tsx - New desktop sidebar component",
      "app/components/Drawer/Drawer.tsx - New mobile drawer component",
      "app/components/HamburgerButton/HamburgerButton.tsx - New hamburger trigger",
      "lib/context/NavigationContext.tsx - New navigation context provider"
    ],
    "css_best_practices": [
      "Use CSS Grid with grid-template-areas for layout",
      "Use media queries at 768px breakpoint for mobile/desktop switch",
      "Use CSS transitions for smooth drawer animations",
      "Use CSS max() function for flexible sidebar widths",
      "No Tailwind or framework CSS - use custom CSS classes only"
    ]
  }
}
