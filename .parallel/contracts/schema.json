{
  "version": "1.0.0",
  "feature": "Reusable Modal Forms and Confirmation Dialogs",
  "freeze_phase": "hot",
  "contracts": {
    "shared": {
      "exports": {
        "public": {
          "types": [
            "ModalConfig",
            "FormFieldConfig",
            "ConfirmationConfig",
            "ModalSize"
          ],
          "functions": [
            "useModal",
            "useConfirmation",
            "validateField"
          ],
          "constants": [
            "MODAL_SIZES",
            "DEFAULT_ANIMATION_DURATION",
            "MODAL_Z_INDEX"
          ]
        },
        "internal": [
          "generateFormFieldId",
          "sanitizeInput",
          "formatValidationMessage"
        ]
      },
      "schemas": {
        "ModalConfig": {
          "type": "object",
          "properties": {
            "isOpen": { "type": "boolean" },
            "onClose": { "type": "function" },
            "title": { "type": "string" },
            "size": { "type": "string", "enum": ["sm", "md", "lg", "xl"] },
            "showCloseButton": { "type": "boolean" },
            "closeOnOverlayClick": { "type": "boolean" },
            "ariaLabelledBy": { "type": "string" },
            "ariaLabel": { "type": "string" },
            "ariaDescribedBy": { "type": "string" },
            "initialFocus": { "type": "string" },
            "returnFocus": { "type": "boolean" }
          },
          "required": ["isOpen", "onClose", "title"]
        },
        "FormFieldConfig": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "label": { "type": "string" },
            "type": { "type": "string", "enum": ["text", "email", "number", "date", "textarea", "select"] },
            "required": { "type": "boolean" },
            "options": { "type": "array", "items": { "type": "string" } },
            "placeholder": { "type": "string" },
            "validation": { "type": "object" },
            "maxLength": { "type": "number" },
            "minLength": { "type": "number" },
            "pattern": { "type": "string" },
            "min": { "type": "number" },
            "max": { "type": "number" }
          },
          "required": ["name", "label", "type", "required"]
        },
        "ConfirmationConfig": {
          "type": "object",
          "properties": {
            "isOpen": { "type": "boolean" },
            "onConfirm": { "type": "function" },
            "onCancel": { "type": "function" },
            "title": { "type": "string" },
            "message": { "type": "string" },
            "confirmText": { "type": "string" },
            "cancelText": { "type": "string" },
            "variant": { "type": "string", "enum": ["danger", "warning", "info"] },
            "ariaLabelledBy": { "type": "string" },
            "ariaLabel": { "type": "string" },
            "ariaDescribedBy": { "type": "string" },
            "initialFocus": { "type": "string" }
          },
          "required": ["isOpen", "onConfirm", "onCancel", "title", "message"]
        },
        "ModalSize": {
          "type": "string",
          "enum": ["sm", "md", "lg", "xl"]
        }
      }
    },
    "forms": {
      "imports_from_shared": [
        "ModalConfig",
        "FormFieldConfig",
        "useModal",
        "validateField",
        "MODAL_SIZES"
      ],
      "exports": [
        "EmployeeForm",
        "ProjectForm",
        "TaskForm"
      ],
      "allowed_internal_helpers": true,
      "file_naming": {
        "pattern": "app/components/forms/{PascalName}/{PascalName}.tsx",
        "example": "app/components/forms/EmployeeForm/EmployeeForm.tsx"
      },
      "react_best_practices": {
        "use_functional_components": true,
        "use_hooks": true,
        "typescript_strict": true,
        "controlled_components": true
      }
    },
    "confirmation": {
      "imports_from_shared": [
        "ConfirmationConfig",
        "useConfirmation",
        "DEFAULT_ANIMATION_DURATION"
      ],
      "exports": [
        "DeleteConfirmation",
        "ActionConfirmation"
      ],
      "allowed_internal_helpers": true,
      "file_naming": {
        "pattern": "app/components/confirmation/{PascalName}/{PascalName}.tsx",
        "example": "app/components/confirmation/DeleteConfirmation/DeleteConfirmation.tsx"
      },
      "react_best_practices": {
        "use_functional_components": true,
        "use_hooks": true,
        "typescript_strict": true,
        "controlled_components": true
      }
    }
  },
  "boundaries": {
    "shared_to_forms": {
      "data_shape": "ModalConfig | FormFieldConfig[]",
      "serialization": "React props",
      "error_shape": { "field": "string", "message": "string" }
    },
    "shared_to_confirmation": {
      "data_shape": "ConfirmationConfig",
      "serialization": "React props",
      "error_shape": { "type": "string", "message": "string" }
    },
    "forms_to_existing": {
      "components": ["EmployeeList", "ProjectList", "TaskList"],
      "integration_pattern": "Replace data-action attributes with React state and event handlers"
    }
  },
  "dependency_graph": {
    "shared": {
      "depends_on": [],
      "blocks": ["forms", "confirmation"]
    },
    "forms": {
      "depends_on": ["shared"],
      "blocks": []
    },
    "confirmation": {
      "depends_on": ["shared"],
      "blocks": []
    }
  }
}
