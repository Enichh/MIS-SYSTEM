{
  "version": "1.0.0",
  "feature": "UI Overhaul - shadcn/ui Integration",
  "freeze_phase": "hot",
  "contracts": {
    "shared": {
      "exports": {
        "public": {
          "types": ["IconName", "IconProps", "ThemeColors", "SpacingScale"],
          "constants": ["ICON_SIZES", "DEFAULT_ICON_SIZE"],
          "functions": ["getIcon", "getThemeColor", "getSpacing"]
        },
        "internal": ["mapIconName", "validateIconProps"]
      },
      "schemas": {
        "IconName": {
          "type": "string",
          "enum": ["menu", "house", "settings", "user", "trash", "edit", "plus", "x", "check", "bell", "search", "filter", "chevron-down", "chevron-up", "chevron-left", "chevron-right"]
        },
        "IconProps": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "size": { "type": "number", "enum": [16, 20, 24, 32] },
            "color": { "type": "string" },
            "className": { "type": "string" }
          },
          "required": ["name"]
        },
        "ThemeColors": {
          "type": "object",
          "properties": {
            "primary": { "type": "string" },
            "background": { "type": "string" },
            "text": { "type": "string" },
            "border": { "type": "string" },
            "success": { "type": "string" },
            "error": { "type": "string" },
            "warning": { "type": "string" }
          }
        },
        "SpacingScale": {
          "type": "object",
          "properties": {
            "xs": { "type": "number", "const": 4 },
            "sm": { "type": "number", "const": 8 },
            "md": { "type": "number", "const": 16 },
            "lg": { "type": "number", "const": 24 },
            "xl": { "type": "number", "const": 32 },
            "2xl": { "type": "number", "const": 48 }
          }
        }
      }
    },
    "core-components": {
      "imports_from_shared": ["IconName", "IconProps", "ICON_SIZES", "DEFAULT_ICON_SIZE", "getIcon"],
      "exports": {
        "public": {
          "components": ["Button", "Input", "Textarea", "Select", "Card", "Badge", "Modal"],
          "types": ["ButtonVariant", "ButtonSize", "InputProps"]
        },
        "internal": ["buttonVariants", "inputVariants"]
      },
      "allowed_internal_helpers": true,
      "file_naming": {
        "pattern": "app/components/ui/{PascalName}/{PascalName}.tsx",
        "example": "app/components/ui/Button/Button.tsx"
      }
    },
    "feature-data": {
      "imports_from_shared": ["IconName", "IconProps", "getIcon", "ICON_SIZES"],
      "imports_from_core-components": ["Button", "Input", "Textarea", "Select", "Card", "Badge", "ButtonVariant"],
      "exports": {
        "public": {
          "components": ["Navigation", "EmployeeList", "ProjectList", "TaskList", "EmployeeForm", "ProjectForm", "TaskForm"]
        }
      },
      "allowed_internal_helpers": true,
      "file_naming": {
        "pattern": "app/components/{PascalName}/{PascalName}.tsx",
        "example": "app/components/Navigation/Navigation.tsx"
      }
    },
    "feature-interactive": {
      "imports_from_shared": ["IconName", "IconProps", "getIcon", "ICON_SIZES"],
      "imports_from_core-components": ["Button", "Input", "Modal", "Badge", "ButtonVariant"],
      "exports": {
        "public": {
          "components": ["ChatModal", "ThemeToggle", "Header", "BaseModal", "ActionConfirmation", "DeleteConfirmation"]
        }
      },
      "allowed_internal_helpers": true,
      "file_naming": {
        "pattern": "app/components/{PascalName}/{PascalName}.tsx",
        "example": "app/components/ChatModal/ChatModal.tsx"
      }
    }
  },
  "boundaries": {
    "shared_to_core-components": {
      "data_shape": "IconName, IconProps, ICON_SIZES",
      "icon_system": "Lucide icons with centralized management",
      "theme_integration": "OKLCH color palette preservation"
    },
    "shared_to_feature-data": {
      "data_shape": "IconName, IconProps, getIcon, ICON_SIZES",
      "icon_system": "Lucide icons with centralized management"
    },
    "shared_to_feature-interactive": {
      "data_shape": "IconName, IconProps, getIcon, ICON_SIZES",
      "icon_system": "Lucide icons with centralized management"
    },
    "core-components_to_feature-data": {
      "component_usage": "shadcn/ui components (Button, Input, Textarea, Select, Card, Badge)",
      "styling_approach": "CSS classes (no inline styles)",
      "state_management": "React state (no DOM manipulation)"
    },
    "core-components_to_feature-interactive": {
      "component_usage": "shadcn/ui components (Button, Input, Modal, Badge)",
      "styling_approach": "CSS classes (no inline styles)",
      "state_management": "React state (no DOM manipulation)"
    }
  },
  "dependency_graph": {
    "shared": {
      "depends_on": [],
      "blocks": ["core-components", "feature-data", "feature-interactive"]
    },
    "core-components": {
      "depends_on": ["shared"],
      "blocks": ["feature-data", "feature-interactive"]
    },
    "feature-data": {
      "depends_on": ["shared", "core-components"],
      "blocks": []
    },
    "feature-interactive": {
      "depends_on": ["shared", "core-components"],
      "blocks": []
    }
  },
  "best_practices": {
    "shadcn_ui": {
      "installation": "npx shadcn@latest init",
      "components": "Use copy-paste model, customize to use existing OKLCH variables",
      "icons": "Lucide icons as default icon library"
    },
    "react_patterns": {
      "navigation": "Use React state (useState) instead of DOM manipulation (classList, getElementById)",
      "styling": "Use CSS classes instead of inline styles",
      "accessibility": "Maintain ARIA labels, focus management, keyboard navigation"
    },
    "nextjs_15": {
      "app_router": "Use 'use client' directive for client components",
      "hooks": "Use next/navigation hooks (useRouter, usePathname) for navigation"
    }
  }
}