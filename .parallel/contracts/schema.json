{
  "version": "1.0.0",
  "feature": "Next.js Migration - Backend First",
  "freeze_phase": "hot",
  "contracts": {
    "shared": {
      "exports": {
        "public": {
          "types": [
            "Employee",
            "Project",
            "Task",
            "ApiResponse",
            "KnowledgeQuery",
            "KnowledgeResponse"
          ],
          "functions": [
            "fetchFromDatabase",
            "validateEmployee",
            "validateProject",
            "validateTask"
          ],
          "constants": [
            "API_BASE_URL",
            "KNOWLEDGE_ENDPOINTS",
            "CHAT_STORAGE_KEY"
          ]
        },
        "internal": [
          "sanitizeQuery",
          "formatKnowledgeResponse",
          "detectQueryIntent",
          "buildKnowledgeContext"
        ]
      },
      "schemas": {
        "Employee": {
          "type": "object",
          "properties": {
            "id": { "type": "string", "pattern": "^emp-[0-9]{3}$" },
            "name": { "type": "string" },
            "email": { "type": "string", "format": "email" },
            "role": { "type": "string" },
            "department": { "type": "string" },
            "projects": { "type": "array", "items": { "type": "string" } }
          },
          "required": ["id", "name", "email", "role", "department"]
        },
        "Project": {
          "type": "object",
          "properties": {
            "id": { "type": "string", "pattern": "^proj-[0-9]{3}$" },
            "name": { "type": "string" },
            "description": { "type": "string" },
            "status": { "type": "string", "enum": ["active", "completed", "on_hold"] },
            "startDate": { "type": "string", "format": "date" },
            "endDate": { "type": "string", "format": "date" }
          },
          "required": ["id", "name", "status"]
        },
        "Task": {
          "type": "object",
          "properties": {
            "id": { "type": "string", "pattern": "^task-[0-9]{3}$" },
            "title": { "type": "string" },
            "description": { "type": "string" },
            "status": { "type": "string", "enum": ["completed", "in_progress", "pending"] },
            "projectId": { "type": "string" },
            "assignedTo": { "type": "string" },
            "dueDate": { "type": "string", "format": "date" }
          },
          "required": ["id", "title", "status", "projectId"]
        },
        "ApiResponse": {
          "type": "object",
          "properties": {
            "code": { "type": "string" },
            "message": { "type": "string" }
          }
        },
        "KnowledgeQuery": {
          "type": "object",
          "properties": {
            "query": { "type": "string" },
            "context": {
              "type": "object",
              "properties": {
                "employeeId": { "type": "string" },
                "projectId": { "type": "string" },
                "taskId": { "type": "string" }
              }
            }
          },
          "required": ["query"]
        },
        "KnowledgeResponse": {
          "type": "object",
          "properties": {
            "answer": { "type": "string" },
            "sources": { "type": "array", "items": { "type": "string" } },
            "confidence": { "type": "number" },
            "relatedEntities": { "type": "object" }
          },
          "required": ["answer"]
        }
      }
    },
    "backend": {
      "imports_from_shared": [
        "Employee",
        "Project",
        "Task",
        "ApiResponse",
        "KnowledgeQuery",
        "KnowledgeResponse",
        "fetchFromDatabase",
        "detectQueryIntent",
        "buildKnowledgeContext"
      ],
      "exports": [
        "GET /api/employees",
        "GET /api/projects",
        "GET /api/tasks",
        "POST /api/knowledge/query"
      ],
      "allowed_internal_helpers": true,
      "file_naming": {
        "pattern": "app/api/{route-name}/route.ts",
        "example": "app/api/employees/route.ts"
      },
      "nextjs_best_practices": {
        "use_app_router": true,
        "use_next_request_response": true,
        "export_http_methods": ["GET", "POST"],
        "default_dynamic_caching": true,
        "use_typescript": true,
        "input_validation": "zod",
        "cors_configuration": "middleware"
      }
    },
    "frontend": {
      "imports_from_shared": [
        "Employee",
        "Project",
        "Task",
        "ApiResponse",
        "KnowledgeQuery",
        "KnowledgeResponse",
        "API_BASE_URL",
        "KNOWLEDGE_ENDPOINTS",
        "CHAT_STORAGE_KEY"
      ],
      "exports": [
        "EmployeeList",
        "ProjectList",
        "TaskList",
        "ChatModal",
        "ThemeToggle"
      ],
      "allowed_internal_helpers": true,
      "file_naming": {
        "pattern": "app/components/{PascalName}/{PascalName}.tsx",
        "example": "app/components/EmployeeList/EmployeeList.tsx"
      },
      "nextjs_best_practices": {
        "use_app_router": true,
        "use_server_components": true,
        "use_typescript": true,
        "incremental_migration": true,
        "maintain_api_compatibility": true
      }
    }
  },
  "boundaries": {
    "shared_to_backend": {
      "data_shape": "Employee[] | Project[] | Task[]",
      "serialization": "JSON",
      "error_shape": { "code": "string", "message": "string" }
    },
    "shared_to_frontend": {
      "data_shape": "Employee[] | Project[] | Task[] | KnowledgeResponse",
      "serialization": "JSON",
      "error_shape": { "code": "string", "message": "string" }
    },
    "frontend_to_backend": {
      "endpoints": [
        "GET /api/employees",
        "GET /api/projects",
        "GET /api/tasks",
        "POST /api/knowledge/query"
      ],
      "request_shape": {
        "query": "string",
        "context": "object"
      },
      "response_shape": {
        "data": "array | object",
        "code": "string",
        "message": "string"
      }
    }
  },
  "dependency_graph": {
    "shared": {
      "depends_on": [],
      "blocks": ["backend", "frontend"]
    },
    "backend": {
      "depends_on": ["shared"],
      "blocks": ["frontend"]
    },
    "frontend": {
      "depends_on": ["shared", "backend"],
      "blocks": []
    }
  }
}