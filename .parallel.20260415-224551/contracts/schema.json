{
  "version": "1.0.0",
  "feature": "UI Overhaul - Modern MIS System Interface",
  "contracts": {
    "shared": {
      "exports": {
        "css_variables": [
          "color-primary",
          "color-primary-hover",
          "color-primary-light",
          "color-background",
          "color-background-secondary",
          "color-background-tertiary",
          "color-surface",
          "color-text",
          "color-text-secondary",
          "color-text-muted",
          "color-border",
          "color-border-light",
          "color-success",
          "color-error",
          "color-warning",
          "color-info",
          "shadow-sm",
          "shadow-md",
          "shadow-lg",
          "shadow-xl",
          "focus-ring",
          "transition-fast",
          "transition-base",
          "transition-slow",
          "font-sans"
        ],
        "spacing_scale": [
          "spacing-xs",
          "spacing-sm",
          "spacing-md",
          "spacing-lg",
          "spacing-xl",
          "spacing-2xl"
        ],
        "typography_scale": [
          "text-xs",
          "text-sm",
          "text-base",
          "text-lg",
          "text-xl",
          "text-2xl",
          "text-3xl"
        ]
      },
      "schemas": {
        "design_tokens": {
          "type": "object",
          "description": "CSS custom properties defining the design system foundation",
          "properties": {
            "color_palette": {
              "type": "object",
              "description": "OKLCH-based color system with primary, background, text, and semantic colors"
            },
            "spacing_system": {
              "type": "object",
              "description": "Consistent spacing scale using 8px base unit"
            },
            "typography_system": {
              "type": "object",
              "description": "Font sizes, weights, and line heights following modern scale"
            },
            "shadow_system": {
              "type": "object",
              "description": "Elevation shadows for depth and hierarchy"
            },
            "transition_system": {
              "type": "object",
              "description": "Consistent animation timings and easing functions"
            }
          },
          "required": ["color_palette", "spacing_system", "typography_system"]
        }
      }
    },
    "frontend-components": {
      "imports_from_shared": [
        "color-primary",
        "color-primary-hover",
        "color-background-secondary",
        "color-text",
        "color-text-secondary",
        "color-border",
        "shadow-md",
        "shadow-lg",
        "transition-base",
        "transition-fast",
        "spacing-md",
        "spacing-lg",
        "text-base",
        "text-lg",
        "text-xl"
      ],
      "exports": [
        "data-card",
        "btn-primary",
        "btn-secondary",
        "btn-danger",
        "form-group",
        "form-input",
        "form-select",
        "form-textarea",
        "modal-overlay",
        "modal-container",
        "notification-toast"
      ],
      "file_naming_convention": "kebab-case for CSS classes, camelCase for JavaScript functions"
    },
    "frontend-layout": {
      "imports_from_shared": [
        "color-background",
        "color-background-secondary",
        "color-text",
        "color-border",
        "spacing-lg",
        "spacing-xl",
        "text-2xl",
        "text-3xl",
        "transition-base"
      ],
      "exports": [
        "header-component",
        "navigation-component",
        "main-content-area",
        "responsive-grid",
        "mobile-nav"
      ],
      "file_naming_convention": "kebab-case for CSS classes, camelCase for JavaScript functions"
    }
  }
}
