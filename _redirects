# Static assets - serve directly
/assets/* /assets/:splat 200

# Netlify functions - preserve function endpoints
/.netlify/functions/* /.netlify/functions/:splat 200

# Source files - preserve full path structure (nested directories)
/src/** /src/:splat 200

# Files with extensions - serve directly (preserves full path)
/*.* /:splat 200

# Catch-all for SPA routing
/* /index.html 200
